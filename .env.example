# Set production in your host environment before publishing online.
APP_ENV=production

# Replace with a long random string.
SECRET_KEY=change-this-to-a-long-random-secret

# On Render, render.yaml wires DATABASE_URL automatically from the managed Postgres instance.
# For local Docker or local PostgreSQL, uncomment and adjust this instead:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timetable_generator?sslmode=disable

# For Netlify, set this to the fully-qualified HTTPS origin of your deployed backend,
# for example: https://your-backend.onrender.com
NETLIFY_BACKEND_ORIGIN=

# Your hosting platform usually injects PORT automatically.
PORT=8000

# Keep this true in production when serving over HTTPS.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
